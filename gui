end

local function hoverify(b, base)
    b.MouseEnter:Connect(function()
        TweenService:Create(b, TweenInfo.new(0.12), { BackgroundColor3 = Color3.new(
            math.min(base.R + 0.06, 1), math.min(base.G + 0.06, 1), math.min(base.B + 0.06, 1)) }):Play()
    end)
    b.MouseLeave:Connect(function()
        TweenService:Create(b, TweenInfo.new(0.12), { BackgroundColor3 = base }):Play()
    end)
end

function GUI:CreateTab(name)
    local btn = Instance.new("TextButton", TabCol)
    btn.Size = UDim2.new(1, 0, 0, 28)
    btn.BackgroundColor3 = C.panel
    btn.BorderSizePixel = 0
    btn.Text = name
    btn.Font = FONT; btn.TextSize = 9; btn.TextColor3 = C.dim
    btn.TextWrapped = true
    btn.ZIndex = 3
    corner(btn, 6)
    stroke(btn, C.stroke, 0.5)

    local page = Instance.new("ScrollingFrame", Content)
    page.Size = UDim2.new(1, 0, 1, 0)
    page.BackgroundTransparency = 1
    page.BorderSizePixel = 0
    page.ScrollBarThickness = 4
    page.ScrollBarImageColor3 = C.accent
    page.CanvasSize = UDim2.new(0, 0, 0, 0)
    page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    page.Visible = false
    page.ZIndex = 3
    local pl = Instance.new("UIListLayout", page); pl.Padding = UDim.new(0, 6); pl.SortOrder = Enum.SortOrder.LayoutOrder
    local pp = Instance.new("UIPadding", page)
    pp.PaddingTop = UDim.new(0, 8); pp.PaddingBottom = UDim.new(0, 8)
    pp.PaddingLeft = UDim.new(0, 8); pp.PaddingRight = UDim.new(0, 8)

    local tab = { page = page, button = btn }

    local function select()
        closeAllDropdowns()
        for _, t in ipairs(tabs) do
            t.page.Visible = false
            t.button.BackgroundColor3 = C.panel
            t.button.TextColor3 = C.dim
        end
        page.Visible = true
        btn.BackgroundColor3 = C.panel2
        btn.TextColor3 = C.text
        activeTab = tab
    end
    btn.MouseButton1Click:Connect(select)
    tab.Select = select

    function tab:Section(text)
        local l = Instance.new("TextLabel", page)
        l.Size = UDim2.new(1, 0, 0, 16); l.BackgroundTransparency = 1
        l.Text = string.upper(text); l.Font = FONT; l.TextSize = 8; l.TextColor3 = C.sub
        l.TextXAlignment = Enum.TextXAlignment.Left; l.ZIndex = 3
        return l
    end

    function tab:Label(text)
        local l = Instance.new("TextLabel", page)
        l.Size = UDim2.new(1, 0, 0, 28); l.AutomaticSize = Enum.AutomaticSize.Y
        l.BackgroundTransparency = 1; l.Text = text; l.Font = FONTN; l.TextSize = 9
        l.TextColor3 = C.dim; l.TextXAlignment = Enum.TextXAlignment.Left
        l.TextWrapped = true; l.ZIndex = 3
        return { Set = function(_, t) l.Text = t end, instance = l }
    end

    function tab:Button(text, callback)
        local b = Instance.new("TextButton", page)
        b.Size = UDim2.new(1, 0, 0, 32)
        b.BackgroundColor3 = C.btnPurp; b.BorderSizePixel = 0
        b.Text = text; b.Font = FONT; b.TextSize = 10; b.TextColor3 = C.text
        b.AutoButtonColor = false; b.ZIndex = 3
        corner(b, 8); stroke(b, C.btnPurpS, 0.25)
        hoverify(b, C.btnPurp)
        b.MouseButton1Click:Connect(function() if callback then task.spawn(callback) end end)
        return { instance = b, SetText = function(_, t) b.Text = t end }
    end

    function tab:Toggle(text, default, callback)
        local row = makeRow(page, 30)
        local box = Instance.new("Frame", row)
        box.Size = UDim2.new(1, 0, 1, 0); box.BackgroundColor3 = C.panel; box.BorderSizePixel = 0; box.ZIndex = 3
        corner(box, 8); stroke(box, C.stroke, 0.4)
        local lbl = Instance.new("TextLabel", box)
        lbl.Size = UDim2.new(1, -48, 1, 0); lbl.Position = UDim2.new(0, 10, 0, 0)
        lbl.BackgroundTransparency = 1; lbl.Text = text; lbl.Font = FONTN; lbl.TextSize = 10
        lbl.TextColor3 = C.text; lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.TextWrapped = true; lbl.ZIndex = 4
        local knob = Instance.new("TextButton", box)
        knob.Size = UDim2.new(0, 34, 0, 18); knob.Position = UDim2.new(1, -40, 0.5, -9)
        knob.Text = ""; knob.BorderSizePixel = 0; knob.ZIndex = 4
        corner(knob, 9)
        local dot = Instance.new("Frame", knob)
        dot.Size = UDim2.new(0, 14, 0, 14); dot.BorderSizePixel = 0; dot.ZIndex = 5
        corner(dot, 7)
        local state = default and true or false
        local function render()
            knob.BackgroundColor3 = state and C.btnGreenS or Color3.fromRGB(60, 60, 78)
            TweenService:Create(dot, TweenInfo.new(0.12), { Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7) }):Play()
            dot.BackgroundColor3 = Color3.fromRGB(235, 235, 245)
        end
        render()
        knob.MouseButton1Click:Connect(function()
            state = not state; render()
            if callback then task.spawn(callback, state) end
        end)
        return { Set = function(_, v) state = v and true or false; render() end, Get = function() return state end }
    end

    function tab:Input(label, placeholder, default, callback)
        local row = makeRow(page, 30)
        local lbl = Instance.new("TextLabel", row)
        lbl.Size = UDim2.new(0, 78, 1, 0); lbl.BackgroundTransparency = 1
        lbl.Text = label; lbl.Font = FONT; lbl.TextSize = 8; lbl.TextColor3 = C.sub
        lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.TextWrapped = true; lbl.ZIndex = 4
        local box = Instance.new("TextBox", row)
        box.Size = UDim2.new(1, -82, 1, 0); box.Position = UDim2.new(0, 82, 0, 0)
        box.BackgroundColor3 = C.panel; box.BorderSizePixel = 0
        box.PlaceholderText = placeholder or ""; box.PlaceholderColor3 = Color3.fromRGB(90, 90, 110)
        box.Text = default or ""; box.Font = FONTN; box.TextSize = 10; box.TextColor3 = C.text
        box.ClearTextOnFocus = false; box.ZIndex = 4
        corner(box, 6); stroke(box, C.stroke, 0.3)
        local bp = Instance.new("UIPadding", box); bp.PaddingLeft = UDim.new(0, 6); bp.PaddingRight = UDim.new(0, 6)
        box.FocusLost:Connect(function() if callback then task.spawn(callback, box.Text) end end)
        return { Get = function() return box.Text end, Set = function(_, t) box.Text = t end, instance = box }
    end

    function tab:Dropdown(label, options, default, callback)
        options = options or {}
        local current = default or options[1]
        local row = makeRow(page, 30)
        local btn = Instance.new("TextButton", row)
        btn.Size = UDim2.new(1, 0, 1, 0); btn.BackgroundColor3 = C.panel; btn.BorderSizePixel = 0
        btn.Font = FONTN; btn.TextSize = 10; btn.TextColor3 = C.text; btn.AutoButtonColor = false
        btn.TextXAlignment = Enum.TextXAlignment.Left; btn.ZIndex = 4
        btn.Text = "  " .. label .. ": " .. tostring(current)
        corner(btn, 6); stroke(btn, C.stroke, 0.3)
        local arrow = Instance.new("TextLabel", btn)
        arrow.Size = UDim2.new(0, 20, 1, 0); arrow.Position = UDim2.new(1, -22, 0, 0)
        arrow.BackgroundTransparency = 1; arrow.Text = "v"; arrow.Font = FONT; arrow.TextSize = 9
        arrow.TextColor3 = C.sub; arrow.ZIndex = 5

        local pop = Instance.new("ScrollingFrame", Main)
        pop.BackgroundColor3 = C.bar; pop.BorderSizePixel = 0; pop.Visible = false
        pop.ScrollBarThickness = 3; pop.ScrollBarImageColor3 = C.accent
        pop.CanvasSize = UDim2.new(0, 0, 0, 0); pop.AutomaticCanvasSize = Enum.AutomaticSize.Y
        pop.ZIndex = 60
        corner(pop, 6); stroke(pop, C.accent, 0.4)
        table.insert(dropdownPops, pop)
        local popLayout = Instance.new("UIListLayout", pop); popLayout.Padding = UDim.new(0, 2)
        local popPad = Instance.new("UIPadding", pop); popPad.PaddingTop = UDim.new(0, 3); popPad.PaddingBottom = UDim.new(0, 3); popPad.PaddingLeft = UDim.new(0, 3); popPad.PaddingRight = UDim.new(0, 3)

        local handle = {}
        local function rebuild()
            for _, c in ipairs(pop:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
            for _, opt in ipairs(options) do
                local o = Instance.new("TextButton", pop)
                o.Size = UDim2.new(1, 0, 0, 24); o.BackgroundColor3 = C.panel; o.BorderSizePixel = 0
                o.Text = tostring(opt); o.Font = FONTN; o.TextSize = 10; o.TextColor3 = C.text; o.AutoButtonColor = false
                o.ZIndex = 61; corner(o, 5)
                hoverify(o, C.panel)
                o.MouseButton1Click:Connect(function()
                    current = opt
                    btn.Text = "  " .. label .. ": " .. tostring(current)
                    pop.Visible = false
                    if callback then task.spawn(callback, current) end
                end)
            end
        end
        rebuild()

        btn.MouseButton1Click:Connect(function()
            if pop.Visible then pop.Visible = false; return end
            closeAllDropdowns()
            local ap = btn.AbsolutePosition - Main.AbsolutePosition
            local h = math.min(#options * 26 + 6, 150)
            pop.Position = UDim2.new(0, ap.X, 0, ap.Y + btn.AbsoluteSize.Y + 2)
            pop.Size = UDim2.new(0, btn.AbsoluteSize.X, 0, h)
            pop.Visible = true
        end)

        handle.Get = function() return current end
        handle.Set = function(_, v) current = v; btn.Text = "  " .. label .. ": " .. tostring(v) end
        handle.SetOptions = function(_, list, keep)
            options = list or {}
            if not keep then current = options[1]; btn.Text = "  " .. label .. ": " .. tostring(current) end
            rebuild()
        end
        return handle
    end

