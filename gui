        scroll.CanvasSize = UDim2.new(0, 0, 0, 0); scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
        scroll.ZIndex = 4
        local sl = Instance.new("UIListLayout", scroll); sl.Padding = UDim.new(0, 3)
        local slp = Instance.new("UIPadding", scroll); slp.PaddingTop = UDim.new(0, 2); slp.PaddingLeft = UDim.new(0, 2); slp.PaddingRight = UDim.new(0, 2)

        local allItems, rows, selected, onSelectCb = {}, {}, nil, nil

        local function clearRows() for _, r in ipairs(rows) do r:Destroy() end; rows = {} end

        local function render(filter)
            clearRows()
            filter = (filter or ""):lower()
            for _, it in ipairs(allItems) do
                if filter == "" or tostring(it.name):lower():find(filter, 1, true) then
                    local r = Instance.new("TextButton", scroll)
                    r.Size = UDim2.new(1, 0, 0, it.sub and 38 or 26)
                    r.BackgroundColor3 = C.bg; r.BorderSizePixel = 0; r.Text = ""; r.AutoButtonColor = false; r.ZIndex = 5
                    corner(r, 6)
                    local rs = stroke(r, C.stroke, 0.4)
                    local nl = Instance.new("TextLabel", r)
                    nl.Size = UDim2.new(1, -8, 0, it.sub and 20 or 26); nl.Position = UDim2.new(0, 6, 0, it.sub and 3 or 0)
                    nl.BackgroundTransparency = 1; nl.Text = it.name; nl.Font = FONT; nl.TextSize = 10
                    nl.TextColor3 = C.text; nl.TextXAlignment = Enum.TextXAlignment.Left; nl.TextTruncate = Enum.TextTruncate.AtEnd; nl.ZIndex = 6
                    if it.sub then
                        local sub = Instance.new("TextLabel", r)
                        sub.Size = UDim2.new(1, -8, 0, 14); sub.Position = UDim2.new(0, 6, 0, 22)
                        sub.BackgroundTransparency = 1; sub.Text = it.sub; sub.Font = FONTN; sub.TextSize = 8
                        sub.TextColor3 = C.ok; sub.TextXAlignment = Enum.TextXAlignment.Left; sub.ZIndex = 6
                    end
                    r.MouseButton1Click:Connect(function()
                        selected = it
                        for _, o in ipairs(rows) do
                            o.BackgroundColor3 = C.bg
                            local st = o:FindFirstChildWhichIsA("UIStroke"); if st then st.Color = C.stroke; st.Transparency = 0.4 end
                        end
                        r.BackgroundColor3 = C.panel2; rs.Color = C.accent; rs.Transparency = 0
                        if onSelectCb then task.spawn(onSelectCb, it) end
                    end)
                    table.insert(rows, r)
                end
