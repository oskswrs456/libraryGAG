        corner(search, 6)
        local sp = Instance.new("UIPadding", search); sp.PaddingLeft = UDim.new(0, 6); sp.PaddingRight = UDim.new(0, 6)

        local scroll = Instance.new("ScrollingFrame", box)
        scroll.Size = UDim2.new(1, -8, 1, -34); scroll.Position = UDim2.new(0, 4, 0, 32)
        scroll.BackgroundTransparency = 1; scroll.BorderSizePixel = 0
